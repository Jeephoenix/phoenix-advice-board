# ╔══════════════════════════════════════════════╗
# ║        Phoenix Advice Board — .env           ║
# ║  Copy this file to .env and fill in values   ║
# ║  NEVER commit your real .env to GitHub       ║
# ╚══════════════════════════════════════════════╝

# ── Wallet ─────────────────────────────────────
# Your MetaMask/Rabby/OKX wallet private key
# How to get: MetaMask → Account Details → Show Private Key
# ⚠️  NEVER share this with anyone ever
PRIVATE_KEY=your_private_key_here

# ── Base Mainnet ────────────────────────────────
# Public RPC (free, no signup needed)
BASE_RPC_URL=https://mainnet.base.org

# OR use Alchemy for better reliability (recommended)
# Sign up free at alchemy.com → Create App → Base Mainnet
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_api_key

# ── Base Sepolia Testnet ────────────────────────
# Public RPC (free, no signup needed)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# OR use Alchemy for better reliability (recommended)
# Sign up free at alchemy.com → Create App → Base Sepolia
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_api_key

# ── BaseScan API Key ────────────────────────────
# Used to verify your contract on BaseScan (optional but recommended)
# How to get: basescan.org → Sign up → My Profile → API Keys → Add
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Notes ───────────────────────────────────────
# 1. Copy this file:     cp .env.example .env
# 2. Fill in values:     open .env and replace placeholders
# 3. Never commit .env:  it is already in .gitignore
# 4. Test on testnet:    always deploy to Base Sepolia first
# 5. Go mainnet:         only after full testnet testing
